{
  "servers": [
    {
      "id": "atlassian-jira",
      "displayName": "Jira (Atlassian)",
      "description": "Official Atlassian MCP — search issues, update tickets, add comments.",
      "endpointUrl": "https://mcp.atlassian.com/v1/mcp/authv2",
      "serverIdPrefix": "jira",
      "authType": "OAUTH_ATLASSIAN",
      "connectMethod": "OAUTH_REDIRECT",
      "credentialFields": [],
      "auth": {
        "kind": "OAUTH",
        "oauth": {
          "providerKey": "atlassian",
          "metadataUrl": "https://mcp.atlassian.com/.well-known/oauth-authorization-server",
          "resource": "https://mcp.atlassian.com/v1/mcp/authv2",
          "scopes": "read:jira-work write:jira-work search:jira-work read:me read:account offline_access",
          "useDcr": true,
          "usePkce": true,
          "includeResourceParam": true,
          "requiresRefreshToken": true
        }
      }
    },
    {
      "id": "gitlab-mcp",
      "displayName": "GitLab",
      "description": "GitLab MCP — manage merge requests, issues, and repository metadata (API token auth).",
      "endpointUrl": "https://gitlab.example.com/api/v4/mcp",
      "serverIdPrefix": "gitlab",
      "authType": "BASIC_EMAIL_TOKEN",
      "connectMethod": "CREDENTIAL_FORM",
      "credentialFields": [
        {
          "key": "email",
          "label": "GitLab username or email",
          "type": "text",
          "required": true
        },
        {
          "key": "apiToken",
          "label": "Personal access token",
          "type": "password",
          "required": true
        }
      ],
      "auth": {
        "kind": "CREDENTIALS"
      }
    }
  ]
}
