      "toolSelection": {
        "continuationNeverSatisfyTools": [
          "jira.getAccessibleAtlassianResources",
          "jira.getJiraProjectIssueTypesMetadata",
          "jira.getJiraIssueTypeMetaWithFields"
        ]
      }
    },
    {
      "id": "gitlab-mcp",
      "llmSkillPath": "classpath:llm/mcp-skills/gitlab.md",
      "displayName": "GitLab",
      "description": "GitLab MCP — merge requests, issues, pipelines, and repository search (Sprinklr GitLab PAT).",
      "endpointUrl": "http://127.0.0.1:3333/mcp",
      "serverIdPrefix": "gitlab",
      "authType": "CREDENTIALS",
      "connectMethod": "CREDENTIAL_FORM",
      "credentialFields": [
        {
          "key": "apiToken",
          "label": "Personal access token (api scope)",
          "type": "password",
          "required": true
        }
      ],
      "auth": {
        "kind": "CREDENTIALS",
        "credentials": {
          "tokenField": "apiToken",
          "headerMode": "PRIVATE_TOKEN"
        }
      },
      "connectProbe": {
        "tool": "list_namespaces",
        "arguments": { "per_page": 1 },
        "failureMessage": "Invalid GitLab personal access token — verify the token has api scope and is not expired."
      }
